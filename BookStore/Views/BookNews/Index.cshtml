@model List<BookStore.Models.BookNews>
@using System.Text.Json

<h2>📢 Book News</h2>
<hr />

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4">
            <div class="card mb-4 shadow-sm">

                @if (!string.IsNullOrEmpty(item.ImageUrl))
                {
                    <img src="@item.ImageUrl" class="card-img-top" style="height:200px; object-fit:cover;" />
                }

                <div class="card-body">
                    <h5>@item.Title</h5>
                    <p>@item.Description</p>

                    <div class="mt-2">
                        @{
                            var likeCount = ViewBag.LikeCounts != null && ViewBag.LikeCounts.ContainsKey(item.Id)
                                ? ViewBag.LikeCounts[item.Id]
                                : 0;

                            var dislikeCount = ViewBag.DislikeCounts != null && ViewBag.DislikeCounts.ContainsKey(item.Id)
                                ? ViewBag.DislikeCounts[item.Id]
                                : 0;
                        }

                        <button class="btn btn-sm btn-outline-success"
                                onclick="react(@item.Id, true, this)">
                            👍 <span class="like-count">@likeCount</span>
                        </button>

                        <button class="btn btn-sm btn-outline-danger"
                                onclick="react(@item.Id, false, this)">
                            👎 <span class="dislike-count">@dislikeCount</span>
                        </button>
                    </div>

                    <!-- 🔥 COMMENT INPUT -->
                    <div class="mt-2">
                        <input type="text" class="form-control comment-input"
                               placeholder="Write a comment..."
                               data-newsid="@item.Id" />
                    </div>

                    <button class="btn btn-sm btn-primary mt-1"
                            onclick="addComment(this)">
                        Comment
                    </button>

                    <!-- 🧠 AJAX COMMENTS (NEW ONES) -->
                    <div class="comments-container mt-3" id="comments-@item.Id"></div>

                    <!-- 🏆 EXISTING COMMENTS (PAGE LOAD) -->
                    <div class="mt-3">
                        @{
                            var allComments = (List<BookStore.Models.Comment>)ViewBag.Comments;

                            var comments = allComments
                                .Where(c => c.BookNewsId == item.Id && c.ParentCommentId == null)
                                .ToList();
                        }

                        @foreach (var c in comments)
                        {
                            <div class="comment mt-2 p-2 border rounded">
                                <b>@(c.User?.UserName?.Split('@')[0] ?? "User")</b>
                                <p>@c.Content</p>

                                <!-- ❌ DELETE -->
                                <button class="btn btn-sm btn-danger"
                                        onclick="deleteComment(@c.Id, this)">
                                    Delete
                                </button>

                                <!-- 🔁 REPLY -->
                                <button class="btn btn-sm btn-link"
                                        onclick="showReplyBox(@c.Id, @item.Id)">
                                    Reply
                                </button>

                                <!-- 💬 REPLY BOX -->
                                <div id="reply-box-@c.Id"></div>

                                <!-- 🔽 REPLIES -->
                                @{
                                    var replies = allComments
                                        .Where(r => r.ParentCommentId == c.Id)
                                        .ToList();
                                }

                                <div id="replies-@c.Id">
                                    @foreach (var r in replies)
                                    {
                                        <div class="ms-4 border-start ps-2 mt-1">
                                            <b>@(r.User?.UserName?.Split('@')[0] ?? "User")</b>
                                            <p>@r.Content</p>

                                            <button class="btn btn-sm btn-danger"
                                                    onclick="deleteComment(@r.Id, this)">
                                                Delete
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <br />

                    <small class="text-muted">
                        Posted on @item.CreatedAt.ToShortDateString()
                    </small>
                </div>
            </div>
        </div>
    }
</div>

<script>
    function react(newsId, isLike, btn) {
        fetch('/BookNews/React', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: `newsId=${newsId}&isLike=${isLike}`
        })
        .then(res => res.json())
        .then(data => {
            const card = btn.closest('.card');
            card.querySelector('.like-count').innerText = data.likeCount;
            card.querySelector('.dislike-count').innerText = data.dislikeCount;
        });
    }

    function addComment(btn) {
        const card = btn.closest('.card');
        const input = card.querySelector('.comment-input');

        const newsId = input.getAttribute('data-newsid');
        const content = input.value;

        if (!content.trim()) return;

        fetch('/BookNews/AddCommentAjax', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: `newsId=${newsId}&content=${content}`
        })
        .then(res => res.json())
        .then(data => {

            const container = document.getElementById("comments-" + newsId);

            const newComment = `
                <div class="comment mt-2 p-2 border rounded">
                    <b>${data.username}</b>
                    <p>${data.content}</p>

                    <button class="btn btn-sm btn-danger"
                            onclick="deleteComment(${data.commentId}, this)">
                        Delete
                    </button>

                    <button class="btn btn-sm btn-link"
                            onclick="showReplyBox(${data.commentId}, ${newsId})">
                        Reply
                    </button>

                    <div id="reply-box-${data.commentId}"></div>
                    <div id="replies-${data.commentId}"></div>
                </div>
            `;

            container.insertAdjacentHTML('beforeend', newComment);
            input.value = "";
        });
    }

    function showReplyBox(commentId, newsId) {
        const box = document.getElementById(`reply-box-${commentId}`);

        box.innerHTML = `
            <input type="text" class="form-control mt-1"
                   id="reply-input-${commentId}" placeholder="Reply..." />

            <button class="btn btn-sm btn-secondary mt-1"
                    onclick="sendReply(${commentId}, ${newsId})">
                Send
            </button>
        `;
    }

    function sendReply(parentId, newsId) {
        const input = document.getElementById(`reply-input-${parentId}`);
        const content = input.value;

        if (!content.trim()) return;

        fetch('/BookNews/AddCommentAjax', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: `newsId=${newsId}&content=${content}&parentCommentId=${parentId}`
        })
        .then(res => res.json())
        .then(data => {

            const replies = document.getElementById(`replies-${parentId}`);

            const replyHtml = `
                <div class="ms-4 border-start ps-2 mt-1">
                    <b>${data.username}</b>
                    <p>${data.content}</p>
                </div>
            `;

            replies.insertAdjacentHTML('beforeend', replyHtml);
            input.value = "";
        });
    }

    function deleteComment(id, element) {
        fetch('/BookNews/DeleteComment', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: `id=${id}`
        })
        .then(() => {
            element.closest('.comment').remove();
        });
    }
</script>