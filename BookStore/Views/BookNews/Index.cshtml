@model List<BookStore.Models.BookNews>

<h2>📢 Book News</h2>
<hr />

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4">
            <div class="card mb-4 shadow-sm">

                @if (!string.IsNullOrEmpty(item.ImageUrl))
                {
                    <img src="@item.ImageUrl" class="card-img-top" style="height:200px; object-fit:cover;" />
                }

                <div class="card-body">
                    <h5>@item.Title</h5>
                    <p>@item.Description</p>

                    <!-- 🔥 LIKE / DISLIKE WITH COUNT -->
                    <div class="mt-2">

                        @{
                            var likeCount = ViewBag.LikeCounts != null && ViewBag.LikeCounts.ContainsKey(item.Id)
                                ? ViewBag.LikeCounts[item.Id]
                                : 0;

                            var dislikeCount = ViewBag.DislikeCounts != null && ViewBag.DislikeCounts.ContainsKey(item.Id)
                                ? ViewBag.DislikeCounts[item.Id]
                                : 0;
                        }

                        <!-- 👍 LIKE -->
                        <form asp-action="React" asp-controller="BookNews" method="post" style="display:inline;">
                            <input type="hidden" name="newsId" value="@item.Id" />
                            <input type="hidden" name="isLike" value="true" />
                            <button type="submit" class="btn btn-sm btn-outline-success">
                                👍 @likeCount
                            </button>
                        </form>

                        <!-- 👎 DISLIKE -->
                        <form asp-action="React" asp-controller="BookNews" method="post" style="display:inline;">
                            <input type="hidden" name="newsId" value="@item.Id" />
                            <input type="hidden" name="isLike" value="false" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                👎 @dislikeCount
                            </button>
                        </form>

                    </div>

                    <br />

                    <small class="text-muted">
                        Posted on @item.CreatedAt.ToShortDateString()
                    </small>
                </div>
            </div>
        </div>
    }
</div>