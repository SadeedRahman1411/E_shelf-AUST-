@model List<BookStore.Models.BookNews>
@using System.Text.Json

<h2>📢 Book News</h2>
<hr />

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4">
            <div class="card mb-4 shadow-sm">

                @if (!string.IsNullOrEmpty(item.ImageUrl))
                {
                    <img src="@item.ImageUrl" class="card-img-top" style="height:200px; object-fit:cover;" />
                }

                <div class="card-body">
                    <h5>@item.Title</h5>
                    <p>@item.Description</p>

                    <div class="mt-2">
                        @{
                            var likeCount = ViewBag.LikeCounts != null && ViewBag.LikeCounts.ContainsKey(item.Id)
                                ? ViewBag.LikeCounts[item.Id]
                                : 0;

                            var dislikeCount = ViewBag.DislikeCounts != null && ViewBag.DislikeCounts.ContainsKey(item.Id)
                                ? ViewBag.DislikeCounts[item.Id]
                                : 0;
                        }

                        <!-- 👍 LIKE -->
                        <button class="btn btn-sm btn-outline-success"
                                onclick="react(@item.Id, true, this)"
                                onmouseover="showUsers(@item.Id, this, true)"
                                onmouseout="hideUsers()">
                            👍 <span class="like-count">@likeCount</span>
                        </button>

                        <!-- 👎 DISLIKE -->
                        <button class="btn btn-sm btn-outline-danger"
                                onclick="react(@item.Id, false, this)"
                                onmouseover="showUsers(@item.Id, this, false)"
                                onmouseout="hideUsers()">
                            👎 <span class="dislike-count">@dislikeCount</span>
                        </button>
                    </div>

                    <!-- 💬 COMMENT FORM -->
                    <form method="post" asp-action="AddComment">
                        <input type="hidden" name="newsId" value="@item.Id" />

                        <div class="mt-2">
                            <input type="text" name="content" class="form-control"
                                   placeholder="Write a comment..." required />
                        </div>

                        <button type="submit" class="btn btn-sm btn-primary mt-1">
                            Comment
                        </button>
                    </form>

                    <!-- 📜 SHOW COMMENTS -->
                    <div class="mt-3">
                        @{
                            var comments = ((List<BookStore.Models.Comment>)ViewBag.Comments)
                                .Where(c => c.BookNewsId == item.Id && c.ParentCommentId == null)
                                .ToList();
                        }

                        @foreach (var c in comments)
                        {
                            <div class="border p-2 mt-2 rounded">
                                <b>@(c.User?.UserName?.Split('@')[0] ?? "User")</b>
                                <p>@c.Content</p>

                                <!-- 🔁 REPLY FORM -->
                                <form method="post" asp-action="AddComment">
                                    <input type="hidden" name="newsId" value="@item.Id" />
                                    <input type="hidden" name="parentCommentId" value="@c.Id" />

                                    <input type="text" name="content"
                                           class="form-control form-control-sm"
                                           placeholder="Reply..." required />

                                    <button class="btn btn-sm btn-secondary mt-1">Reply</button>
                                </form>

                                <!-- 🔽 SHOW REPLIES -->
                                @{
                                    var replies = ((List<BookStore.Models.Comment>)ViewBag.Comments)
                                        .Where(r => r.ParentCommentId == c.Id)
                                        .ToList();
                                }

                                @foreach (var r in replies)
                                {
                                    <div class="ms-4 mt-2 border-start ps-2">
                                        <b>@(r.User?.UserName?.Split('@')[0] ?? "User")</b>
                                        <p>@r.Content</p>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <br />

                    <small class="text-muted">
                        Posted on @item.CreatedAt.ToShortDateString()
                    </small>
                </div>
            </div>
        </div>
    }
</div>

<!-- 🔥 TOOLTIP -->
<div id="userTooltip" style="
    position:absolute;
    display:none;
    background:#222;
    color:white;
    padding:10px;
    border-radius:8px;
    font-size:12px;
    z-index:999;">
</div>

<script>
    const likedUsers = @Html.Raw(JsonSerializer.Serialize(ViewBag.LikedUsers));
    const dislikedUsers = @Html.Raw(JsonSerializer.Serialize(ViewBag.DislikedUsers));

    function react(newsId, isLike, btn) {
        fetch('/BookNews/React', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: `newsId=${newsId}&isLike=${isLike}`
        })
        .then(res => res.json())
        .then(data => {
            const card = btn.closest('.card');

            card.querySelector('.like-count').innerText = data.likeCount;
            card.querySelector('.dislike-count').innerText = data.dislikeCount;
        });
    }

    function showUsers(newsId, btn, isLike) {
        const tooltip = document.getElementById("userTooltip");

        let users = isLike ? likedUsers[newsId] : dislikedUsers[newsId];

        if (users && users.length > 0) {
            tooltip.innerHTML = users.join("<br>");
        } else {
            tooltip.innerHTML = "No reactions yet";
        }

        tooltip.style.display = "block";

        const rect = btn.getBoundingClientRect();
        tooltip.style.left = rect.left + "px";
        tooltip.style.top = (rect.top - 40) + "px";
    }

    function hideUsers() {
        document.getElementById("userTooltip").style.display = "none";
    }
</script>