@model BookStore.Models.Book

@{
    ViewData["Title"] = "Details";
}
<div>
    <a asp-action="Index"><i class="fa-solid fa-backward"></i>Back to List</a>
</div>


<h1>Details</h1>

<div>
    <h4>Book</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Language)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Language)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ISBN)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ISBN)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DatePublished)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DatePublished)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Author)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Author)
        </dd>
        <dt class="col-sm-2">
            Book Cover
        </dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="img-thumbnail" style="display:inline-block; padding:10px;">
                    @* The referrerpolicy attribute is the key to stopping Google from blocking the image *@
                    <img src="@Model.ImageUrl" alt="@Model.Title"
                         style="max-width:300px; height:auto; border-radius:8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);"
                         referrerpolicy="no-referrer"
                         crossorigin="anonymous" />
                </div>
            }
            else
            {
                <span class="text-muted">No image available</span>
            }
        </dd>
        <dt class="col-sm-2">
            Book Document
        </dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.PdfUrl))
            {
                <a href="@Model.PdfUrl" target="_blank" class="btn btn-outline-danger">
                    <i class="fa-solid fa-file-pdf fa-2x"></i>
                    <span class="ms-2">Read / Download PDF</span>
                </a>
            }
            else
            {
                <span class="text-muted">No PDF available for this book</span>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id"><i class="fa-solid fa-pen-to-square"></i>Edit</a> |
</div>
@if (ViewBag.BookStatus == BookStore.Models.BookStatus.Report_Ack
    && ViewBag.ReportMessage != null)
{
    <div class="alert alert-danger mt-3">
        <strong>Report Reason:</strong>
        <p>@ViewBag.ReportMessage</p>
    </div>
}
