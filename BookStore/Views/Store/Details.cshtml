@model BookStore.Models.Book

@{
    ViewData["Title"] = "Book Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>Details</h1>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-backward"></i> Back to List
        </a>
    </div>

    <div class="card shadow-sm border-0 mt-3">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4 text-center border-end">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded shadow-sm"
                             style="max-height: 450px; width: auto;" referrerpolicy="no-referrer" />
                    }
                    else
                    {
                        <div class="p-5 bg-light border rounded">
                            <i class="fa-solid fa-image fa-4x text-muted"></i>
                            <p class="text-muted mt-2">No Image Available</p>
                        </div>
                    }
                    
                    @if (!string.IsNullOrEmpty(Model.PdfUrl))
                    {
                        <div class="mt-3">
                            <a href="@Model.PdfUrl" target="_blank" class="btn btn-sm btn-outline-danger w-100">
                                <i class="fa-solid fa-file-pdf"></i> Preview Digital Copy
                            </a>
                        </div>
                    }
                </div>

                <div class="col-md-8 ps-md-4">
                    <h2 class="display-6">@Model.Title</h2>
                    <p class="lead text-muted">by @Model.Author</p>
                    
                    <h3 class="text-success my-3">@Model.Price.ToString("C")</h3>

                    <div class="d-flex gap-2 my-4">
                        <button class="btn btn-primary btn-lg px-4">
                            <i class="fa-solid fa-cart-arrow-down me-2"></i>Add to Cart
                        </button>
                        <button class="btn btn-success btn-lg px-4">
                            <i class="fa-solid fa-bag-shopping me-2"></i>Purchase Now
                        </button>
                    </div>

                    <hr />

                    <dl class="row mt-4">
                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Author)</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Author)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Description)</dt>
                        <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Language)</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Language)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ISBN)</dt>
                        <dd class="col-sm-9"><code>@Html.DisplayFor(model => model.ISBN)</code></dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DatePublished)</dt>
                        <dd class="col-sm-9">@Model.DatePublished.ToString("MMMM dd, yyyy")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>