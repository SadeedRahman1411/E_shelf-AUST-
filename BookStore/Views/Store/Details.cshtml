@model BookStore.Models.Book
@inject BookStore.Models.Cart CartService

@{
    ViewData["Title"] = "Book Details";
    var purchased = ViewBag.PurchasedBookIds as List<int>;
    bool isOwned = User.IsInRole("Reader") &&
                   purchased != null &&
                   purchased.Contains(Model.Id);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>Details</h1>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-backward"></i> Back to List
        </a>
    </div>

    <div class="card shadow-sm border-0 mt-3">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4 text-center border-end">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded shadow-sm"
                             style="max-height: 450px; width: auto;" referrerpolicy="no-referrer" />
                    }
                    else
                    {
                        <div class="p-5 bg-light border rounded">
                            <i class="fa-solid fa-image fa-4x text-muted"></i>
                            <p class="text-muted mt-2">No Image Available</p>
                        </div>
                    }

                     @if (User.IsInRole("Admin") && !string.IsNullOrEmpty(Model.PdfUrl))
                     {
                        <div class="mt-3">
                            <a href="@Model.PdfUrl"
                                target="_blank"
                                class="btn btn-outline-danger btn-sm w-100">
                                <i class="fa-solid fa-file-pdf"></i> View PDF
                            </a>
                        </div>
                     }
                    
                </div>

                <div class="col-md-8 ps-md-4">
                    <h2 class="display-6">@Model.Title</h2>
                    <p class="lead text-muted">by @Model.Author</p>

                    <h3 class="text-success my-3">@Model.Price.ToString("C")</h3>

                    <div class="d-flex gap-2 my-4">

                        @if (isOwned)
                        {
                            <a asp-controller="Reader"
                               asp-action="PurchasedBooks"
                               class="btn btn-secondary btn-lg px-4">
                                <i class="fa-solid fa-book me-2"></i>Go to My Books
                            </a>
                        }
                        else
                        {

                            @if (User.IsInRole("Reader"))
                            {
                                @if (CartService.IsBookInCart(Model.Id))
                                {
                                    <a asp-controller="Cart"
                                       asp-action="Index"
                                       class="btn btn-outline-primary btn-lg px-4">
                                        <i class="fa-solid fa-circle-check me-2"></i>In Cart
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="Cart"
                                       asp-action="AddToCart"
                                       asp-route-id="@Model.Id"
                                       class="btn btn-primary btn-lg px-4">
                                        <i class="fa-solid fa-cart-arrow-down me-2"></i>Add to Cart
                                    </a>
                                }
                                <form asp-controller="Cart" asp-action="PurchaseSingle" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="bookId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-success btn-lg px-4">
                                        <i class="fa-solid fa-bag-shopping me-2"></i>Purchase Now
                                    </button>
                                </form>
                            }

                            @if (User.IsInRole("Reader") && Model.Status == BookStore.Models.BookStatus.Allowed)
                            {
                                <form asp-controller="Store" asp-action="ReportBook" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-warning btn-lg px-4">
                                        <i class="fa-solid fa-flag me-2"></i>Report Book
                                    </button>
                                </form>
                            }
                        }

                    </div>

                    <hr />

                    <dl class="row mt-4">
                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Author)</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Author)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Description)</dt>
                        <dd class="col-sm-9">
                            @(string.IsNullOrEmpty(Model.Description)
                                                        ? "No description provided."
                                                        : Model.Description)
                        </dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Language)</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Language)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ISBN)</dt>
                        <dd class="col-sm-9">
                            <code>@Html.DisplayFor(model => model.ISBN)</code>
                        </dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DatePublished)</dt>
                        <dd class="col-sm-9">
                            @Model.DatePublished.ToString("MMMM dd, yyyy")
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>
@{
    var reviews = ViewBag.Reviews as List<BookStore.Models.Review>;
    var userReview = ViewBag.UserReview as BookStore.Models.Review;
}

<hr />
<h3>Reviews</h3>

@if (reviews != null && reviews.Any())
{
    foreach (var r in reviews)
    {
        <div class="border p-3 mb-3 rounded">
            <strong>@(r.User?.FirstName ?? "User")</strong>
            <span class="text-warning">⭐ @r.Rating</span>

            <p class="mb-1">@r.Comment</p>
            <small class="text-muted">@r.CreatedAt.ToString("g")</small>

            @if (User.Identity.IsAuthenticated &&
                             (r.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                             || User.IsInRole("Admin")))
            {
                <div class="mt-2 d-flex gap-2">

                    <!-- DELETE -->
                    <form asp-controller="Review" asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@r.Id" />
                        <button class="btn btn-danger btn-sm">Delete</button>
                    </form>

                    <!-- EDIT (prefills form below automatically) -->
                </div>
            }
        </div>
    }
}
else
{
    <p class="text-muted">No reviews yet.</p>
}

@if (isOwned)
{
    <hr />
    <h3>@(userReview == null ? "Add Review" : "Edit Your Review")</h3>

    <form asp-controller="Review"
          asp-action="@(userReview == null ? "Add" : "Edit")"
          method="post"
          class="mt-3">

        @Html.AntiForgeryToken()

        @if (userReview != null)
        {
            <input type="hidden" name="id" value="@userReview.Id" />
        }

        <input type="hidden" name="bookId" value="@Model.Id" />

        <div class="mb-2">
            <label class="form-label">Rating</label>
            <select name="rating" class="form-select w-25">
                <option value="1" selected="@(userReview?.Rating == 1)">1</option>
                <option value="2" selected="@(userReview?.Rating == 2)">2</option>
                <option value="3" selected="@(userReview?.Rating == 3)">3</option>
                <option value="4" selected="@(userReview?.Rating == 4)">4</option>
                <option value="5" selected="@(userReview?.Rating == 5)">5</option>
            </select>
        </div>

        <div class="mb-2">
            <label class="form-label">Comment</label>
            <textarea name="comment" class="form-control" rows="3">
@userReview?.Comment
</textarea>
        </div>

        <button type="submit" class="btn btn-primary">
            @(userReview == null ? "Submit Review" : "Update Review")
        </button>
    </form>
}